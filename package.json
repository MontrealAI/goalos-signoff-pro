    "site:verify:workflows": "node scripts/check-workflow-script-integrity.mjs",
    "site:verify:routes": "node scripts/check-site-route-integrity.mjs",
    "site:verify:all": "npm run site:verify:workflows && npm run site:verify:routes && npm run site:verify:public-labs"
