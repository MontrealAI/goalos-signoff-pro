    "repo:all": "npm run repo:codeowners && npm run repo:verify && npm run package:verify && npm run hybrid:anchor:check",
    "repo:codeowners": "node scripts/check-codeowners-owner.mjs",
    "institutional:verify": "node scripts/verify-institutional-excellence.mjs",
