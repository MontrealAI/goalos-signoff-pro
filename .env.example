# GoalOS Signoff Pro v1.1.0 — copy to .env.local locally and configure in your host as secrets.
# Never commit .env.local, signing credentials, wallet recovery information, or production API keys.

# Core SaaS app
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOALOS_ENVIRONMENT=private-beta

# Supabase Auth/Postgres/Storage
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY
SUPABASE_SERVICE_ROLE_KEY=

# Receipt signing — generated with npm run setup:keys
RECEIPT_SIGNING_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
RECEIPT_SIGNING_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
RECEIPT_SIGNING_KEY_ID=goalos-signoff-pro-2026-01

# Email invitations
RESEND_API_KEY=
RESEND_FROM_EMAIL=GoalOS Signoff <signoff@example.com>

# Pilot monetization: Stripe is optional. Signoff works without it.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_CUSTOMER_PORTAL_URL=
STRIPE_WEBHOOK_SECRET=
GOALOS_INVOICE_MODE=manual
GOALOS_BILLING_TRIAL_SIGNOFFS=10

# Optional AI evidence assistant. Default is deterministic/offline checks only.
GOALOS_EVIDENCE_ASSISTANT_MODE=deterministic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional verified receipts. Start with Sepolia only.
NEXT_PUBLIC_ENABLE_VERIFIED_SIGNOFF=false
NEXT_PUBLIC_SIGNOFF_ANCHOR_ENABLED=false
NEXT_PUBLIC_SIGNOFF_ANCHOR_CHAIN_ID=11155111
NEXT_PUBLIC_SIGNOFF_ANCHOR_ADDRESS=
NEXT_PUBLIC_SIGNOFF_ANCHOR_EXPLORER=https://sepolia.etherscan.io
GOALOS_IPFS_MODE=disabled
GOALOS_IPFS_API_URL=
GOALOS_IPFS_API_TOKEN=
ANCHOR_RPC_URL=
ANCHOR_CHAIN_ID=11155111
ANCHOR_CONTRACT_ADDRESS=
ANCHOR_RELAYER_PRIVATE_KEY=
GOALOS_ANCHOR_REQUIRE_HUMAN_APPROVAL=true
GOALOS_ANCHOR_MAX_DAILY_RECEIPTS=25
GOALOS_MAINNET_ANCHORING_ENABLED=false

# AGIALPHA and escrow are intentionally disabled in v1.1.
AGIALPHA_PROTOCOL_MODE=disabled_until_protocol_gates_pass
GOALOS_ESCROW_MODE=disabled
